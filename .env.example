# Fourthwall Open API (Basic Auth) — sync:fourthwall
FOURTHWALL_API_USERNAME=
FOURTHWALL_API_PASSWORD=
FOURTHWALL_API_BASE_URL=https://api.fourthwall.com/open-api/v1
NEXT_PUBLIC_FW_API_URL=https://storefront-api.fourthwall.com/v1
FOURTHWALL_PRODUCT_LIMIT=24

# Eventbrite — sync:shows
EVENTBRITE_TOKEN=
EVENTBRITE_ORGANIZER_ID=

# YouTube — sync:youtube
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
YOUTUBE_CHANNEL_HANDLE=
YOUTUBE_MAX_RESULTS=6

# Instagram Graph API — sync:instagram
# Long-lived user token (~60 day expiry). Refresh via npm run refresh:instagram-token
# or rotate manually in Meta for Developers.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_MAX_RESULTS=9

# Facebook Graph API — sync:facebook + sync:facebook-events
# Page-level token (same Meta app as Instagram).
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_POSTS_LIMIT=5

# Patreon RSS — sync:patreon (optional)
# Public RSS feed URL. Patreon does not provide a public posts API.
PATREON_RSS_URL=

# Plausible Analytics (optional)
# Set to your verified domain (e.g. stonedgooseproductions.com) to enable.
# Leave unset for no analytics. Script ships from plausible.io.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Search Console verification meta tag (optional)
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools verification meta tag (optional)
NEXT_PUBLIC_BING_VERIFICATION=

# IndexNow ping key (optional). When set, GitHub Actions can ping
# Bing/Yandex/etc. with changed URLs after a successful main build.
INDEXNOW_KEY=
