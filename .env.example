# =====================================================================
# Social feed secrets (feeds:instagram, feeds:youtube, feeds:facebook)
# In production these live in GitHub Actions repo secrets, NOT in .env.
# Keep them out of NEXT_PUBLIC_* names so they never reach the client.
# =====================================================================

# Instagram Graph API (graph.instagram.com). Long-lived user token,
# ~60 day expiry. Refresh via npm run refresh:instagram-token.
INSTAGRAM_ACCESS_TOKEN=

# YouTube Data API v3 key. Restrict the key to YouTube Data API v3 in
# Google Cloud Console. The channel ID lives in content/site.ts under
# site.social.youtubeChannelId, not in env.
YOUTUBE_API_KEY=

# Facebook Page access token (Meta for Developers app, page-level perms).
# Prefer a never-expiring page token (extend via Graph API). The page ID
# lives in content/site.ts under site.social.facebookPageId, not in env.
FACEBOOK_PAGE_ACCESS_TOKEN=

# =====================================================================
# Other build-time integrations (sync:* scripts)
# =====================================================================

# Fourthwall Open API (Basic Auth) — sync:fourthwall
FOURTHWALL_API_USERNAME=
FOURTHWALL_API_PASSWORD=
FOURTHWALL_API_BASE_URL=https://api.fourthwall.com/open-api/v1
NEXT_PUBLIC_FW_API_URL=https://storefront-api.fourthwall.com/v1
FOURTHWALL_PRODUCT_LIMIT=24

# Eventbrite — sync:shows
EVENTBRITE_TOKEN=
EVENTBRITE_ORGANIZER_ID=

# Facebook Events sync (sync:facebook-events). Reuses
# FACEBOOK_PAGE_ACCESS_TOKEN above. Page ID still env-driven here for
# backwards compat with that script.
FACEBOOK_PAGE_ID=

# Patreon RSS — sync:patreon (optional). Public RSS feed URL.
# Patreon does not provide a public posts API.
PATREON_RSS_URL=

# =====================================================================
# Site instrumentation (optional)
# =====================================================================

# Plausible Analytics. Set to your verified domain to enable.
# Leave unset for no analytics. Script ships from plausible.io.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Search Console verification meta tag (optional)
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools verification meta tag (optional)
NEXT_PUBLIC_BING_VERIFICATION=

# IndexNow ping key (optional). When set, GitHub Actions can ping
# Bing/Yandex/etc. with changed URLs after a successful main build.
INDEXNOW_KEY=
